<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_screen_soft">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_horse_info"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/theme_surface"
        android:elevation="3dp"
        app:title="Informations du cheval"
        app:titleTextColor="@color/theme_text_primary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_surface_card"
                android:elevation="2dp"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Fiche du cheval"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/theme_text_primary"
                    android:gravity="center"
                    android:layout_marginBottom="16dp" />

                <ImageView
                    android:id="@+id/img_info_horse"
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:layout_gravity="center"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_surface_card_tinted"
                    android:padding="6dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/logo_equ" />

                <TextView
                    android:id="@+id/tv_info_horse_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nom du cheval"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/theme_text_primary"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tv_info_horse_parent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Parent"
                    android:textColor="@color/theme_text_secondary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_info_horse_elevage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Elevage"
                    android:textColor="@color/theme_text_secondary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_info_horse_race"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Race"
                    android:textColor="@color/theme_text_secondary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_info_horse_age"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Age"
                    android:textColor="@color/theme_text_secondary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_info_horse_today"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cours aujourd'hui"
                    android:textColor="@color/theme_text_secondary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_info_horse_health"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Etat de sante"
                    android:textColor="@color/theme_text_secondary"
                    android:layout_marginBottom="16dp" />

                <Button
                    android:id="@+id/btn_update_horse_state"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_button_secondary"
                    android:text="Mettre a jour l'etat"
                    android:textAllCaps="false"
                    android:textColor="@color/theme_text_primary" />

                <Button
                    android:id="@+id/btn_schedule_horse_session"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_button_primary"
                    android:text="Programmer une seance"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white" />

                <Button
                    android:id="@+id/btn_back_horse_info"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_button_secondary"
                    android:text="Retour"
                    android:textAllCaps="false"
                    android:textColor="@color/theme_text_primary" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</LinearLayout>
