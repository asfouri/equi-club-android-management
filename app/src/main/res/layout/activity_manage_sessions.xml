<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_soft"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_sessions"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/theme_surface"
        android:elevation="3dp"
        app:title="Planning intelligent"
        app:titleTextColor="@color/theme_text_primary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_admin_hero"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Planning du club"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_session_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="0 seance"
                android:textColor="#DDEDE9" />
        </LinearLayout>

        <EditText
            android:id="@+id/et_search_session"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@drawable/rounded_edittext"
            android:hint="Rechercher cheval, cavalier ou date"
            android:inputType="text"
            android:paddingHorizontal="14dp"
            android:paddingVertical="12dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_filter_all_sessions"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_button_primary"
                    android:minWidth="92dp"
                    android:text="Tout"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white" />

                <Button
                    android:id="@+id/btn_filter_today_sessions"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_button_secondary"
                    android:minWidth="92dp"
                    android:text="Aujourd'hui"
                    android:textAllCaps="false"
                    android:textColor="@color/theme_text_primary" />

                <Button
                    android:id="@+id/btn_filter_week_sessions"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_button_secondary"
                    android:minWidth="92dp"
                    android:text="Semaine"
                    android:textAllCaps="false"
                    android:textColor="@color/theme_text_primary" />

                <Button
                    android:id="@+id/btn_filter_alert_sessions"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_button_secondary"
                    android:minWidth="92dp"
                    android:text="Alertes"
                    android:textAllCaps="false"
                    android:textColor="@color/theme_text_primary" />
            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:id="@+id/tv_empty_sessions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_surface_card"
            android:gravity="center"
            android:padding="18dp"
            android:text="Aucune seance ne correspond a ces criteres."
            android:textColor="@color/theme_text_secondary"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_sessions"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginBottom="12dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

        <Button
            android:id="@+id/btn_add_session"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_button_primary"
            android:text="Planifier une seance"
            android:textAllCaps="false"
            android:textColor="@android:color/white" />

    </LinearLayout>

</LinearLayout>
