<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_surface_card"
    android:elevation="1dp"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_session_heure"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_admin_hero"
            android:minWidth="68dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:text="09:00"
            android:textAlignment="center"
            android:textColor="@android:color/white"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_session_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_status_info"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:text="Prevue"
            android:textColor="@color/theme_info"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_session_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Date : 10/04/2026"
        android:textColor="@color/theme_text_secondary" />

    <TextView
        android:id="@+id/tv_session_cavalier"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Cavalier : Yassine Alaoui"
        android:textColor="@color/theme_text_primary"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_session_cheval"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Cheval : Denver de Berni"
        android:textColor="@color/theme_text_secondary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_edit_session"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_secondary"
            android:text="Modifier"
            android:textAllCaps="false"
            android:textColor="@color/theme_text_primary" />

        <Button
            android:id="@+id/btn_delete_session"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_secondary"
            android:text="Annuler"
            android:textAllCaps="false"
            android:textColor="@color/theme_text_primary" />
    </LinearLayout>

</LinearLayout>
