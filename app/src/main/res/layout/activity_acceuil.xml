<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_screen_soft">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_accueil"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/theme_surface"
        android:elevation="3dp"
        app:title="Espace chevalier"
        app:titleTextColor="@color/theme_text_primary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_hero_rider"
            android:elevation="2dp"
            android:padding="18dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:id="@+id/tv_bienvenue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Espace chevalier"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/theme_text_primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Retrouve rapidement les chevaux disponibles et gere tes demandes sans passer par les ecrans admin."
                android:textColor="@color/theme_text_secondary"
                android:layout_marginBottom="14dp" />

            <Button
                android:id="@+id/btn_logout"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:background="@drawable/bg_button_secondary"
                android:text="Quitter"
                android:textAllCaps="false"
                android:textColor="@color/theme_text_primary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_surface_card"
            android:elevation="1dp"
            android:padding="14dp"
            android:layout_marginBottom="12dp">

            <EditText
                android:id="@+id/et_search_horse"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_edittext"
                android:hint="Chercher un cheval"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_search_horse"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_button_primary"
                    android:text="Rechercher"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white" />

                <Button
                    android:id="@+id/btn_reset_horse"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_button_secondary"
                    android:text="Effacer"
                    android:textAllCaps="false"
                    android:textColor="@color/theme_text_primary" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btn_show_day"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_chip_active"
                android:text="Du jour"
                android:textAllCaps="false"
                android:textColor="@android:color/white" />

            <Button
                android:id="@+id/btn_show_rest"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_chip_inactive"
                android:text="Au repos"
                android:textAllCaps="false"
                android:textColor="@color/theme_text_primary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <Button
                android:id="@+id/btn_manage_session"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_button_primary"
                android:text="Seances"
                android:textAllCaps="false"
                android:textColor="@android:color/white" />

            <Button
                android:id="@+id/btn_contact"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_button_secondary"
                android:text="Contact"
                android:textAllCaps="false"
                android:textColor="@color/theme_text_primary" />

            <Button
                android:id="@+id/btn_about"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_button_secondary"
                android:text="A propos"
                android:textAllCaps="false"
                android:textColor="@color/theme_text_primary" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_titre_chevaux"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chevaux du jour"
            android:textSize="19sp"
            android:textStyle="bold"
            android:textColor="@color/theme_text_primary"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Touchez une carte pour voir le detail du cheval"
            android:textColor="@color/theme_text_secondary"
            android:layout_marginBottom="10dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_chevaux"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

    </LinearLayout>

</LinearLayout>
