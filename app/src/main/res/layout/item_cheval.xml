<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="14dp"
    android:background="@drawable/bg_surface_card"
    android:elevation="1dp"
    android:layout_marginBottom="10dp">

    <ImageView
        android:id="@+id/img_horse_club"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/bg_surface_card_tinted"
        android:padding="4dp"
        android:scaleType="centerCrop"
        android:src="@drawable/logo_equ" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_club_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nom du cheval"
                android:textSize="19sp"
                android:textStyle="bold"
                android:textColor="@color/theme_text_primary" />

            <TextView
                android:id="@+id/tv_club_state"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_good"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:text="Bon"
                android:textColor="@color/theme_text_primary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_club_race"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Race"
            android:textColor="@color/theme_text_secondary"
            android:layout_marginTop="6dp" />

        <TextView
            android:id="@+id/tv_club_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Details"
            android:textColor="@color/theme_text_secondary"
            android:layout_marginTop="4dp" />
    </LinearLayout>

</LinearLayout>
