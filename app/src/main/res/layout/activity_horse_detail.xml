<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_screen_soft">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_horse_detail"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/theme_surface"
        android:elevation="3dp"
        app:title="Gestion du cheval"
        app:titleTextColor="@color/theme_text_primary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_surface_card"
                android:elevation="2dp"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:gravity="center"
                    android:text="Gestion du cheval"
                    android:textColor="@color/theme_text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/img_detail_horse"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_gravity="center"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_surface_card_tinted"
                    android:padding="6dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/logo_equ" />

                <EditText
                    android:id="@+id/et_horse_nom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/rounded_edittext"
                    android:hint="Nom"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp" />

                <EditText
                    android:id="@+id/et_horse_parent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/rounded_edittext"
                    android:hint="Parent"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp" />

                <EditText
                    android:id="@+id/et_horse_elevage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/rounded_edittext"
                    android:hint="Elevage"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp" />

                <EditText
                    android:id="@+id/et_horse_race"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/rounded_edittext"
                    android:hint="Race"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp" />

                <EditText
                    android:id="@+id/et_horse_age"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/rounded_edittext"
                    android:hint="Age"
                    android:inputType="number"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp" />

                <EditText
                    android:id="@+id/et_horse_today"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/rounded_edittext"
                    android:hint="Cours aujourd'hui ? oui/non"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp" />

                <EditText
                    android:id="@+id/et_horse_state"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="18dp"
                    android:background="@drawable/rounded_edittext"
                    android:hint="Etat de sante : bon ou malade"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn_add_horse"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/bg_button_primary"
                        android:text="Ajouter"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white" />

                    <Button
                        android:id="@+id/btn_update_horse"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/bg_button_secondary"
                        android:text="Modifier"
                        android:textAllCaps="false"
                        android:textColor="@color/theme_text_primary" />

                    <Button
                        android:id="@+id/btn_delete_horse"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/bg_button_secondary"
                        android:text="Supprimer"
                        android:textAllCaps="false"
                        android:textColor="@color/theme_text_primary" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_back_horse"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_button_secondary"
                    android:text="Retour"
                    android:textAllCaps="false"
                    android:textColor="@color/theme_text_primary" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</LinearLayout>
