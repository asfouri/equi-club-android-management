<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_screen_soft">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_add_user"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/theme_surface"
        android:elevation="3dp"
        app:titleTextColor="@color/theme_text_primary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_surface_card"
                android:elevation="2dp"
                android:padding="18dp">

                <TextView
                    android:id="@+id/tv_title_add_user"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Ajouter un utilisateur"
                    android:textColor="@color/theme_text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="18dp"
                    android:text="Renseignez les informations essentielles du cavalier avant validation."
                    android:textColor="@color/theme_text_secondary" />

                <EditText
                    android:id="@+id/et_add_user_nom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/rounded_edittext"
                    android:hint="Nom complet"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp" />

                <EditText
                    android:id="@+id/et_add_user_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/rounded_edittext"
                    android:hint="Email"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp" />

                <EditText
                    android:id="@+id/et_add_user_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/rounded_edittext"
                    android:hint="Mot de passe"
                    android:inputType="textPassword"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp" />

                <EditText
                    android:id="@+id/et_add_user_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/rounded_edittext"
                    android:hint="Telephone"
                    android:inputType="phone"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp" />

                <EditText
                    android:id="@+id/et_add_user_diplome"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="18dp"
                    android:background="@drawable/rounded_edittext"
                    android:hint="Niveau ou diplome"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp" />

                <Button
                    android:id="@+id/btn_save_new_user"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_button_primary"
                    android:text="Enregistrer"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white" />

                <Button
                    android:id="@+id/btn_cancel_add_user"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_button_secondary"
                    android:text="Annuler"
                    android:textAllCaps="false"
                    android:textColor="@color/theme_text_primary" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</LinearLayout>
