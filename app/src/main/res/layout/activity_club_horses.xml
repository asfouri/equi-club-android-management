<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_soft"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_club_horses"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/theme_surface"
        android:elevation="3dp"
        app:title="Registre chevaux"
        app:titleTextColor="@color/theme_text_primary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_admin_hero"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chevaux du club"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_horse_registry_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="0 chevaux"
                android:textColor="#DDEDE9" />
        </LinearLayout>

        <EditText
            android:id="@+id/et_search_club"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@drawable/rounded_edittext"
            android:hint="Rechercher nom, race, cavalier"
            android:inputType="text"
            android:paddingHorizontal="14dp"
            android:paddingVertical="12dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_filter_horses_all"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_button_primary"
                    android:minWidth="90dp"
                    android:text="Tous"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white" />

                <Button
                    android:id="@+id/btn_filter_horses_ready"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_button_secondary"
                    android:minWidth="90dp"
                    android:text="Disponibles"
                    android:textAllCaps="false"
                    android:textColor="@color/theme_text_primary" />

                <Button
                    android:id="@+id/btn_filter_horses_sick"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_button_secondary"
                    android:minWidth="90dp"
                    android:text="Malades"
                    android:textAllCaps="false"
                    android:textColor="@color/theme_text_primary" />

                <Button
                    android:id="@+id/btn_filter_horses_stopped"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_button_secondary"
                    android:minWidth="90dp"
                    android:text="Arretes"
                    android:textAllCaps="false"
                    android:textColor="@color/theme_text_primary" />
            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:id="@+id/tv_selected_horse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_surface_card"
            android:padding="12dp"
            android:text="Touchez un cheval pour le selectionner."
            android:textColor="@color/theme_text_secondary" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_club_horses"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginBottom="12dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_add_horse_list"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_primary"
                android:text="Ajouter"
                android:textAllCaps="false"
                android:textColor="@android:color/white" />

            <Button
                android:id="@+id/btn_update_horse_list"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_secondary"
                android:text="Modifier"
                android:textAllCaps="false"
                android:textColor="@color/theme_text_primary" />

            <Button
                android:id="@+id/btn_delete_horse_list"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_secondary"
                android:text="Retirer"
                android:textAllCaps="false"
                android:textColor="@color/theme_text_primary" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
